//@version=5
// ══════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════
indicator(
     title            = "Thenula Trader",
     shorttitle       = "THW",
     overlay          = true,
     max_labels_count = 500,
     max_lines_count  = 500,
     max_boxes_count  = 200)

// ══════════════════════════════════════
// INPUTS
// ══════════════════════════════════════
GRP_MAIN   = "⚙️ Main Settings"
GRP_VISUAL = "🎨 Visual"
GRP_DASH   = "📊 Dashboard"
GRP_COLORS = "🎨 Colors"

sourceInput  = input.source(close, "Source", group = GRP_MAIN)
lengthInput  = input.int(21, "Trend Length", minval = 5, group = GRP_MAIN)
atrLenInput  = input.int(14, "ATR Length", minval = 5, group = GRP_MAIN)
atrMultInput = input.float(2.0, "Band Multiplier", step = 0.1, group = GRP_MAIN)

showSignalsInput   = input.bool(true, "Show Buy/Sell Signals", group = GRP_VISUAL)
showTrendLineInput = input.bool(true, "Show Trend Line", group = GRP_VISUAL)
showDashInput      = input.bool(true, "Show Dashboard", group = GRP_DASH)
dashPosStr         = input.string("Top Right", "Position", options = ["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group = GRP_DASH)

bullColorInput    = input.color(#00E676, "Bull", group = GRP_COLORS)
bearColorInput    = input.color(#FF5252, "Bear", group = GRP_COLORS)
neutralColorInput = input.color(#FFEB3B, "Neutral", group = GRP_COLORS)


// FUNCTIONS 

f_safeDiv(num, den) => den != 0 ? num / den : 0.0

f_calcER(src, len) =>
    float dir = math.abs(src - nz(src[len], src))
    float vol = math.sum(math.abs(src - nz(src[1], src)), len)
    f_safeDiv(dir, vol)

f_calcAVT(src, len) =>
    float er = f_calcER(src, len)
    float sc = math.pow(er * (2.0/3.0 - 2.0/31.0) + 2.0/31.0, 2)
    var float m = na
    m := na(m) ? src : nz(m[1], src) + sc * (src - nz(m[1], src))
    [m, er]

f_get_mtf() =>
    [m, er] = f_calcAVT(close, 21)
    [m, er, m[1]]


// 

[m5, e5, p5]     = request.security(syminfo.tickerid, "5", f_get_mtf())
[m15, e15, p15]   = request.security(syminfo.tickerid, "15", f_get_mtf())
[m30, e30, p30]   = request.security(syminfo.tickerid, "30", f_get_mtf())
[m60, e60, p60]   = request.security(syminfo.tickerid, "60", f_get_mtf())
[m240, e240, p240] = request.security(syminfo.tickerid, "240", f_get_mtf())
[m1d, e1d, p1d]   = request.security(syminfo.tickerid, "1D", f_get_mtf())


//  CHART CALCULATIONS

[mainLine, mainER] = f_calcAVT(sourceInput, lengthInput)
isBull = mainLine > mainLine[1]
isBear = mainLine < mainLine[1]

confirmedBuy  = ta.crossover(mainLine, mainLine[1])
confirmedSell = ta.crossunder(mainLine, mainLine[1])


// DASHBOARD 

var table dashTbl = na
if showDashInput and barstate.islast
    pos = dashPosStr == "Top Left" ? position.top_left : dashPosStr == "Bottom Left" ? position.bottom_left : dashPosStr == "Bottom Right" ? position.bottom_right : position.top_right
    dashTbl := table.new(pos, 3, 8, #131722, #2A2E39, 1, #2A2E39, 1)
    
    table.cell(dashTbl, 0, 0, "Trend", bgcolor=#2962FF, text_color=color.white, text_size=size.small)
    table.merge_cells(dashTbl, 0, 0, 2, 0)
    
    table.cell(dashTbl, 0, 1, "TF", bgcolor=#1C2030, text_color=color.gray, text_size=size.small)
    table.cell(dashTbl, 1, 1, "TREND", bgcolor=#1C2030, text_color=color.gray, text_size=size.small)
    table.cell(dashTbl, 2, 1, "EFF %", bgcolor=#1C2030, text_color=color.gray, text_size=size.small)

    
    table.cell(dashTbl, 0, 2, "5m", text_color=color.white)
    table.cell(dashTbl, 1, 2, m5 > p5 ? "BULLISH" : "BEARISH", text_color=m5 > p5 ? bullColorInput : bearColorInput)
    table.cell(dashTbl, 2, 2, str.tostring(e5 * 100, "0") + "%", text_color=color.white)
    
    table.cell(dashTbl, 0, 3, "15m", text_color=color.white)
    table.cell(dashTbl, 1, 3, m15 > p15 ? "BULLISH" : "BEARISH", text_color=m15 > p15 ? bullColorInput : bearColorInput)
    table.cell(dashTbl, 2, 3, str.tostring(e15 * 100, "0") + "%", text_color=color.white)

    table.cell(dashTbl, 0, 4, "30m", text_color=color.white)
    table.cell(dashTbl, 1, 4, m30 > p30 ? "BULLISH" : "BEARISH", text_color=m30 > p30 ? bullColorInput : bearColorInput)
    table.cell(dashTbl, 2, 4, str.tostring(e30 * 100, "0") + "%", text_color=color.white)

    table.cell(dashTbl, 0, 5, "1h", text_color=color.white)
    table.cell(dashTbl, 1, 5, m60 > p60 ? "BULLISH" : "BEARISH", text_color=m60 > p60 ? bullColorInput : bearColorInput)
    table.cell(dashTbl, 2, 5, str.tostring(e60 * 100, "0") + "%", text_color=color.white)

    table.cell(dashTbl, 0, 6, "4h", text_color=color.white)
    table.cell(dashTbl, 1, 6, m240 > p240 ? "BULLISH" : "BEARISH", text_color=m240 > p240 ? bullColorInput : bearColorInput)
    table.cell(dashTbl, 2, 6, str.tostring(e240 * 100, "0") + "%", text_color=color.white)

    table.cell(dashTbl, 0, 7, "1D", text_color=color.white)
    table.cell(dashTbl, 1, 7, m1d > p1d ? "BULLISH" : "BEARISH", text_color=m1d > p1d ? bullColorInput : bearColorInput)
    table.cell(dashTbl, 2, 7, str.tostring(e1d * 100, "0") + "%", text_color=color.white)


plot(showTrendLineInput ? mainLine : na, "Trend", color=isBull ? bullColorInput : bearColorInput, linewidth=3)

plotshape(showSignalsInput and confirmedBuy, title="Buy", style=shape.labelup, location=location.belowbar, color=bullColorInput, text="BUY", textcolor=color.white, size=size.small)
plotshape(showSignalsInput and confirmedSell, title="Sell", style=shape.labeldown, location=location.abovebar, color=bearColorInput, text="SELL", textcolor=color.white, size=size.small)
